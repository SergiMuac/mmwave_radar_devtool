.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Type checking and lint caches
.mypy_cache/
.ruff_cache/
.pyre/

# Notebook and local tooling
.ipynb_checkpoints/

# Editors and OS files
.DS_Store
.idea/
.vscode/

# Local capture outputs and logs
*.bin
*.log
*.pcap

